# ============================================
# 阿里云 DashScope 统一 API Key（推荐）
# 一个 key 同时用于：Qwen 文本生成 + CosyVoice 语音 + Wan2.x 视频
# 申请地址：https://dashscope.console.aliyun.com/
# ============================================
DASHSCOPE_API_KEY=

# ============================================
# 可选：如果你想用其他文本生成服务（覆盖 DashScope Qwen）
# ============================================
# PROXY_API_KEY=
# PROXY_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# TEXT_MODEL=qwen-plus

# ============================================
# 可选：如果你想单独配置语音 key（覆盖 DASHSCOPE_API_KEY）
# ============================================
# COSYVOICE_API_KEY=
# TTS_VOICE=longyue_v3

# ============================================
# 其他配置
# ============================================
# TTS_ENV_SILENCE_SECONDS=4.0
# TOTAL_VIDEO_MINUTES=15
# SKIP_FINAL_VIDEO_RENDER=true
